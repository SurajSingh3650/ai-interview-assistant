NODE_ENV=development
PORT=8082

MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=aicopilot
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1h
REALTIME_TOKEN_EXPIRES_IN=10m

# OpenRouter is the active AI provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.2
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# OpenAI is commented out
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

AI_TIMEOUT_MS=15000
AI_HELP_RATE_LIMIT=30
AI_HELP_RATE_LIMIT_WINDOW_SEC=60
SESSION_MEMORY_TTL_SEC=21600
SESSION_MEMORY_MAX_TURNS=6
TRANSCRIPTION_PROVIDER=pass_through

AI_PROVIDER=openrouter
AI_MODEL_REALTIME=gpt-4o-mini-realtime
AI_MODEL_ANALYSIS=gpt-4.1-mini
LOG_LEVEL=info
